<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#FFB86B</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />

    <Color x:Key="AppBackgroundColor">#E6F2FF</Color>
    <Color x:Key="AppForegroundColor">#0B2545</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="SearchBorderColor">#000000</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="{StaticResource AppForegroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />

    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray950">#141414</Color>

    <Color x:Key="PrimaryDark">#D46A00</Color>
    <Color x:Key="PrimaryDarkAlt">#512BD4</Color>
    <Color x:Key="AppBackgroundDark">#0B2545</Color>
    <Color x:Key="AppForegroundDark">#E6F2FF</Color>
    <Color x:Key="CardBackgroundDark">#212121</Color>
    <Color x:Key="SurfaceDark">#141414</Color>
    <Color x:Key="BorderDark">#6E6E6E</Color>
    <SolidColorBrush x:Key="CardBackgroundDarkBrush" Color="{StaticResource CardBackgroundDark}" />

</ResourceDictionary>
