<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WeatherApp.Views.MainPage"
             x:DataType="viewModels:MainPageViewModel"
             xmlns:viewModels="clr-namespace:WeatherApp.ViewModels"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <StackLayout Background="{AppThemeBinding Light={StaticResource AppBackgroundColor}, Dark={StaticResource AppBackgroundDark}}">

            <Button Command="{Binding NavigateToSettingsCommand}"
                CornerRadius="20"
                Margin="0,50,20,0"
                HorizontalOptions="End"
                Background="Transparent"
                VerticalOptions="Start"
                ImageSource="settings.png" WidthRequest="75" HeightRequest="50">
            </Button>

            <StackLayout  VerticalOptions="End" 
                      Padding="10"
                      Margin="0,50,0,0">

                <Label Text="Weather App" 
                       TextColor="{AppThemeBinding Light={StaticResource AppForegroundColor}, Dark={StaticResource AppForegroundDark}}"    
                       HorizontalOptions="Center"
                       FontAttributes="Bold"
                       FontSize="35"/>

                <Image Source="weather.png"
                       HeightRequest="220"
                       WidthRequest="220" 
                       HorizontalOptions="Center" 
                       Aspect="AspectFit"/>

                <Button Text="Get Started" HeightRequest="48"
                        VerticalOptions="Start"
                        WidthRequest="200"
                        Margin="0,20"
                        CornerRadius="8" 
                        TextColor="{AppThemeBinding Light={StaticResource AppForegroundColor}, Dark={StaticResource AppForegroundDark}}"
                        Command="{Binding NavigateToSearchCommand}" 
                        Background="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
            </StackLayout>
        </StackLayout>

        <ActivityIndicator IsRunning="{Binding IsLoading}" 
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="48" HeightRequest="48"
                           Color="DeepSkyBlue"/>

    </Grid>

</ContentPage>
