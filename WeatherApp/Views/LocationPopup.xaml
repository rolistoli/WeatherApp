<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WeatherApp.Views.LocationPopup"
             x:DataType="viewModels:LocationPopupViewModel"
             xmlns:viewModels="clr-namespace:WeatherApp.ViewModels"
             ZIndex="10"
             Margin="12"
             HorizontalOptions="Center"
             VerticalOptions="End">

    <Border BackgroundColor="White" 
            Stroke="Black"
            StrokeShape="RoundRectangle 18"
            WidthRequest="360" HeightRequest="130"
            IsEnabled="{Binding IsNotLoading}">

        <Grid>

            <Image Source="{Binding WeatherImage}" 
                   Aspect="AspectFit" 
                   HeightRequest="120"/>

            <Button HorizontalOptions="End" 
                    VerticalOptions="Start" 
                    Text="✕"
                    TextColor="Black"
                    Background="Transparent"
                    Command="{Binding CloseCommand}">
            </Button>

            <Button Text="Details" 
                    Margin="12"
                    Command="{Binding DetailsCommand}"
                    VerticalOptions="End"
                    HorizontalOptions="End"
                    Background="LightBlue"
                    TextColor="Black" 
                    FontAttributes="Bold"
                    IsEnabled="{Binding IsNotLoading}"
                    IsVisible="{Binding IsNotLoading}"/>

            <StackLayout Padding="12">

                <Label Text="{Binding Title}"
                       FontAttributes="Bold"/>

                <Label Text="{Binding Subtitle}"
                       FontSize="14" 
                       TextColor="Gray"/>

                <Label Text="{Binding Temperature}"
                       FontSize="20" 
                       FontAttributes="Bold"/>

                <Label Text="{Binding Description}" FontSize="18"
                       Margin="0,7,0,0"
                       TextColor="DodgerBlue"
                       FontAttributes="Bold"/>

            </StackLayout>

            <ActivityIndicator IsRunning="{Binding IsLoading}" 
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               WidthRequest="24" HeightRequest="24"
                               Color="DeepSkyBlue"/>
        </Grid>
    </Border>

</ContentView>
