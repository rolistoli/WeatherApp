<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:WeatherApp.Views"
             x:Class="WeatherApp.Views.LocationPopupPage"
             BackgroundColor="Transparent"
             NavigationPage.HasNavigationBar="False">

    <Grid x:Name="RootGrid" BackgroundColor="Transparent" HorizontalOptions="Fill" VerticalOptions="Fill">
        <BoxView BackgroundColor="#80000000" HorizontalOptions="Fill" VerticalOptions="Fill" />
        <views:LocationPopup HorizontalOptions="Center" VerticalOptions="End"/>
    </Grid>
</ContentPage>