<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WeatherApp.Views.ErrorPopup"
             BackgroundColor="#80000000"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <!-- Outer tappable area to dismiss the modal -->
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" NumberOfTapsRequired="1" />
        </Grid.GestureRecognizers>

        <Border
            BackgroundColor="White"
            Stroke="DarkRed"
            StrokeShape="RoundRectangle 22"
            StrokeThickness="1"
            WidthRequest="320" HeightRequest="150"
            Padding="1">

            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label x:Name="IconLabel" FontSize="28" VerticalOptions="Center" TextColor="DarkRed" />
                    <Label x:Name="TitleLabel" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <ScrollView HeightRequest="100" Padding="12,2">
                    <Label x:Name="MessageLabel" LineBreakMode="WordWrap" />
                </ScrollView>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
