<?xml version="1.0" encoding="utf-8" ?>
<ContentPage    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
                xmlns:viewModels="clr-namespace:WeatherApp.ViewModels"
                xmlns:views="clr-namespace:WeatherApp.Views"
                xmlns:models="clr-namespace:WeatherApp.Models"
                x:Class="WeatherApp.Views.SearchPage"
                x:DataType="viewModels:SearchViewModel"
                NavigationPage.HasNavigationBar="False">   

    <Grid IsEnabled="{Binding IsNotLoading}">

        <mapsui:MapControl x:Name="MapControl" 
                           Loaded="MapControl_Loaded"
                           MapTapped="MapControl_MapTapped"/>

        <ActivityIndicator IsVisible="{Binding IsLoading}" 
                           IsRunning="{Binding IsLoading}"
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"
                           WidthRequest="48" HeightRequest="48"
                           Color="DeepSkyBlue" />
        
        <Grid Padding="24,36"
              VerticalOptions="Start"
              ZIndex="0">

            <VerticalStackLayout>

                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundColor}, Dark={StaticResource SurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource SearchBorderColor}, Dark={StaticResource BorderDark}}"
                        StrokeShape="RoundRectangle 18">

                    <Grid Padding="18,12"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12"
                          VerticalOptions="Center">

                        <Label Text="⌕"
                               FontSize="26"
                               VerticalOptions="Center"
                               TextColor="Gray" />

                        <Entry Grid.Column="1"
                               Text="{Binding CityName}"
                               ReturnType="Done"
                               TextColor="{AppThemeBinding Light={StaticResource AppForegroundColor}, Dark={StaticResource AppForegroundDark}}"
                               FontSize="18"
                               Placeholder="Search"
                               BackgroundColor="Transparent"
                               Focused="CityEntry_Focused" />

                        <ActivityIndicator
                            Grid.Column="2"
                            IsRunning="{Binding IsEntryLoading}"
                            IsVisible="{Binding IsEntryLoading}"
                            WidthRequest="24"
                            HeightRequest="24"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border IsVisible="{Binding HasResults}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundColor}, Dark={StaticResource SurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource SearchBorderColor}, Dark={StaticResource BorderDark}}"
                        StrokeShape="RoundRectangle 14"
                        Margin="0,6,0,0"
                        ZIndex="1">

                    <CollectionView ItemsSource="{Binding Results}"
                                    SelectedItem="{Binding SelectedLocation}"
                                    SelectionMode="Single"
                                    HeightRequest="260">

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CityLocation">
                                <Grid Padding="18,12"
                                      RowDefinitions="Auto,Auto">

                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           TextColor="{AppThemeBinding Light={StaticResource AppForegroundColor}, Dark={StaticResource AppForegroundDark}}"
                                           FontAttributes="Bold" />

                                    <HorizontalStackLayout Grid.Row="1" Spacing="6">
                                        <Label Text="{Binding Admin1}"
                                               FontSize="13"
                                               TextColor="Gray" />

                                        <Label Text="{Binding Country}"
                                               FontSize="13"
                                               TextColor="Gray" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>               

            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
